{
  "kind": "collectionType",
  "collectionName": "news_items",
  "info": {
    "singularName": "news",
    "pluralName": "news-items",
    "displayName": "News"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "content-manager": {
      "visible": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "maxLength": 200,
      "required": true
    },
    "author": {
      "type": "string",
      "maxLength": 200
    },
    "abstract": {
      "type": "text",
      "maxLength": 250,
      "required": true
    },
    "newsContent": {
      "type": "richtext",
      "required": true
    },
    "news_tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::event-tag.event-tag",
      "inversedBy": "news"
    },
    "coverImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    }
  }
}
