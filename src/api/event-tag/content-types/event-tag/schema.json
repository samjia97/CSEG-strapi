{
  "kind": "collectionType",
  "collectionName": "event_tags",
  "info": {
    "singularName": "event-tag",
    "pluralName": "event-tags",
    "displayName": "Topics"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "tagName": {
      "type": "string",
      "maxLength": 30,
      "required": true,
      "unique": true
    },
    "events": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::event.event",
      "inversedBy": "event_tags"
    },
    "internalOnlyTagDescription": {
      "type": "text",
      "private": true,
      "required": true
    },
    "publications": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::publication.publication",
      "mappedBy": "topics"
    },
    "research_projects": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::research-project.research-project",
      "inversedBy": "research_topics"
    },
    "news": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::news.news",
      "mappedBy": "news_tags"
    }
  }
}
