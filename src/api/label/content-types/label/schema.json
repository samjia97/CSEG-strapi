{
  "kind": "collectionType",
  "collectionName": "labels",
  "info": {
    "singularName": "label",
    "pluralName": "labels",
    "displayName": "Label"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "labelName": {
